FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
MAX_CONTENT_LENGTH_MB=25
UPLOAD_DIR=tmp/uploads
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
AUDIO_PREPROCESSING_ENABLED=true
AUDIO_PREPROCESSING_TIMEOUT_SECONDS=30
PREPROCESSED_SAMPLE_RATE=16000
AUDIO_FILTER=highpass=f=70,lowpass=f=7600,afftdn=nf=-20,loudnorm=I=-18:TP=-1.5:LRA=11,silenceremove=start_periods=1:start_threshold=-45dB:start_silence=0.2:stop_periods=-1:stop_threshold=-45dB:stop_silence=0.5
MIN_AUDIO_DURATION_SECONDS=0
MAX_AUDIO_DURATION_SECONDS=180
STREAM_DIR=tmp/streams
DATABASE_PATH=data/medical_ai.db
PDF_UPLOAD_DIR=data/pdfs
CONTEXT_VOCABULARY_PATH=data/context_vocabulary.json
STREAM_TRANSCRIBE_INTERVAL_SECONDS=0.8
STREAM_MAX_CHUNK_BYTES=1048576
STREAM_MAX_BYTES_PER_SECOND=1048576
STREAM_MAX_SESSION_SECONDS=1800
WHISPER_MAX_WORKERS=1
WHISPER_MODEL_SIZE=large-v3
WHISPER_MODEL_PATH=models/faster-whisper-large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=10
WHISPER_BEST_OF=10
WHISPER_PATIENCE=1.0
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPER_LOW_CONFIDENCE_LOGPROB_THRESHOLD=-0.85
WHISPER_VAD_FILTER=true
WHISPER_VAD_MIN_SILENCE_DURATION_MS=500
WHISPER_VAD_SPEECH_PAD_MS=250
WHISPER_NO_SPEECH_THRESHOLD=0.6
WHISPER_HALLUCINATION_SILENCE_THRESHOLD=2.0
WHISPER_TEMPERATURE=0.0
WHISPER_INITIAL_PROMPT=
WHISPER_ENGLISH_PROMPT=
WHISPER_TRANSLATION_PROMPT=
WHISPER_HOTWORDS=Hemoglobin HbA1c Creatinine Platelet WBC RBC Sodium Potassium Cholesterol Triglycerides TSH T3 T4 Diabetes Hypertension Cardiology Neurology Gastroenterology Prescription Consultation Admission Discharge
WHISPER_USE_HOTWORDS=false
ENTITY_NAME_THRESHOLD=80
ENTITY_LOCATION_THRESHOLD=65
ENTITY_HOSPITAL_THRESHOLD=82
ENTITY_DOCTOR_THRESHOLD=82
ENTITY_MEDICAL_THRESHOLD=82
CONFIRMATION_ALTERNATIVE_COUNT=3
WORD_LOW_CONFIDENCE_THRESHOLD=0.65
WHISPER_SUPPORTED_LANGUAGES=en,hi
WHISPER_RETRY_UNSUPPORTED_LANGUAGE=true
WHISPER_FALLBACK_LANGUAGE=hi
